        O1["~/.gathon/dashboard.html\nstandalone · no server needed"]
    end

    S1 --> A1
    S2 --> A2
    S3 --> A3
    S4 --> A4

    A1 & A2 & A3 & A4 --> L1
    A1 & A2 & A3 & A4 --> L2
    A1 & A2 & A3 & A4 --> L3
    A2 --> L4

    L1 --> T6
    L2 --> T7
    L3 --> T8
    A1 --> T2
    A2 --> T3 & T4
    A3 --> T5
    A1 & A2 & A3 & A4 --> T1

    T1 & T2 & T3 & T4 & T5 & T6 & T7 & T8 --> RENDER
    RENDER --> O1

